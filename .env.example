# ── Agent Meeting Platform ──
# Copy this file to .env and fill in real values before deploying.

# Backend
SECRET_KEY=change-me-to-a-random-string
DATABASE_URL=postgresql+asyncpg://agentmeeting:agentmeeting@postgres:5432/agentmeeting
DB_SCHEMA=agent_meeting
REDIS_URL=redis://redis:6379/0
DEBUG=true

# LLM (optional — meetings work without it, but LLM-powered features need a key)
LLM_MODEL=openrouter/google/gemini-2.5-flash
LLM_API_KEY=
OPENROUTER_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Demo agents
MEETING_SERVER=http://backend:8000
