# Agent Meeting Platform SDK — demo runner
FROM python:3.12-slim

WORKDIR /app

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copy SDK
COPY pyproject.toml uv.lock README.md ./
COPY agent_meeting/ agent_meeting/

# Install SDK
RUN uv sync --frozen --no-dev --no-install-project && \
    uv pip install .

# Copy demo script
COPY examples/docker_demo.py /app/docker_demo.py

CMD ["python", "/app/docker_demo.py"]
